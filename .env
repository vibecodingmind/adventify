# Local development database (PostgreSQL via SQLite-compatible URL for sandbox)
# For Railway, this is overridden by the DATABASE_URL environment variable
DATABASE_URL="file:./db/custom.db"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Certificate System
CERTIFICATE_SIGNING_KEY="your-certificate-signing-key-change-in-production"

# Digital Wallet (Optional)
GOOGLE_WALLET_SERVICE_ACCOUNT=""
GOOGLE_WALLET_PRIVATE_KEY=""

# Email Configuration (Optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# Blockchain (Optional - for enhanced security)
BLOCKCHAIN_API_KEY=""
BLOCKCHAIN_NETWORK="ethereum"

# Environment
NODE_ENV="development"

# Port
PORT="3000"
